{
	"name": "gakrcli-vscode",
	"displayName": "GakrCLI VS Code",
	"description": "GakrCLI VS Code: AI coding assistant powered by any LLM",
	"version": "0.2.1",
	"publisher": "gakr-gakr",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/gajjalaashok75-UI/gakrcli-vscode.git"
	},
	"bugs": {
		"url": "https://github.com/gajjalaashok75-UI/gakrcli-vscode/issues"
	},
	"engines": {
		"vscode": "^1.94.0"
	},
	"categories": [
		"AI",
		"Chat"
	],
	"keywords": [
		"gakrcli",
		"sonnet",
		"ai",
		"mcp",
		"agent"
	],
	"activationEvents": [
		"onStartupFinished",
		"onWebviewPanel:gakrcliPanel"
	],
	"icon": "resources/gakrcli-logo.png",
	"main": "./dist/extension.js",
	"contributes": {
		"configuration": {
			"title": "GakrCLI",
			"properties": {
				"gakrcliCode.selectedModel": {
					"type": "string",
					"default": "default",
					"description": "The AI model for GakrCLI."
				},
				"gakrcliCode.environmentVariables": {
					"type": "array",
					"items": {
						"type": "object",
						"properties": {
							"name": {
								"type": "string",
								"description": "Environment variable name"
							},
							"value": {
								"type": "string",
								"description": "Environment variable value"
							}
						},
						"required": [
							"name",
							"value"
						]
					},
					"default": [],
					"description": "Environment variables to set when launching GakrCLI. Saved GakrCLI provider profiles are loaded automatically from the workspace or user config directory."
				},
				"gakrcliCode.useTerminal": {
					"type": "boolean",
					"default": false,
					"description": "Launch GakrCLI in the terminal instead of the native UI."
				},
				"gakrcliCode.allowDangerouslySkipPermissions": {
					"type": "boolean",
					"description": "Allow bypass permissions mode. Recommended only for sandboxes with no internet access."
				},
				"gakrcliCode.processWrapper": {
					"type": "string",
					"description": "Executable path used to launch GakrCLI."
				},
				"gakrcliCode.respectGitIgnore": {
					"type": "boolean",
					"default": true,
					"description": "Respect .gitignore files when performing file searches. Tip: You can still filter by other exclusion patterns in .ignore when this is disabled."
				},
				"gakrcliCode.initialPermissionMode": {
					"type": "string",
					"enum": [
						"default",
						"acceptEdits",
						"plan",
						"bypassPermissions"
					],
					"default": "default",
					"description": "Initial permission mode for new conversations."
				},
				"gakrcliCode.disableLoginPrompt": {
					"type": "boolean",
					"default": false,
					"description": "When true, never prompt for login/authentication in the extension. Used when authentication is handled externally."
				},
				"gakrcliCode.autosave": {
					"type": "boolean",
					"default": true,
					"description": "Automatically save files before GakrCLI reads or writes them."
				},
				"gakrcliCode.useCtrlEnterToSend": {
					"type": "boolean",
					"default": false,
					"description": "When enabled, use Ctrl/Cmd+Enter to send prompts instead of just Enter. This allows Enter to create new lines."
				},
				"gakrcliCode.preferredLocation": {
					"type": "string",
					"enum": [
						"sidebar",
						"panel"
					],
					"enumDescriptions": [
						"Sidebar (Right)",
						"Panel (New Tab)"
					],
					"default": "panel",
					"description": "Where GakrCLI opens by default. This setting updates automatically when you open GakrCLI in a new location."
				},
				"gakrcliCode.enableNewConversationShortcut": {
					"type": "boolean",
					"default": false,
					"description": "Use the Cmd/Ctrl+N keyboard shortcut to start a new conversation when GakrCLI is focused."
				},
				"gakrcliCode.hideOnboarding": {
					"type": "boolean",
					"default": false,
					"description": "Hide the onboarding checklist in GakrCLI."
				},
				"gakrcliCode.usePythonEnvironment": {
					"type": "boolean",
					"default": true,
					"markdownDescription": "Automatically activate the workspace's Python environment when running GakrCLI. Requires the [Python](https://marketplace.visualstudio.com/items?itemName=ms-python.python) extension."
				},
				"gakrcliCode.selectedProvider": {
					"type": "string",
					"default": "anthropic",
					"description": "The selected AI provider for GakrCLI."
				},
				"gakrcliCode.apiKey": {
					"type": "string",
					"default": "",
					"description": "API key for the selected provider."
				},
				"gakrcliCode.baseUrl": {
					"type": "string",
					"default": "",
					"description": "Base URL for the selected provider (for custom/OpenAI-compatible providers)."
				}
			}
		},
		"jsonValidation": [
			{
				"fileMatch": [
					"**/.gakrcli/settings.json",
					"**/.gakrcli/settings.local.json"
				],
				"url": "./gakrcli-settings.schema.json"
			}
		],
		"commands": [
			{
				"command": "gakrcli.editor.open",
				"title": "GakrCLI: Open in New Tab",
				"icon": {
					"light": "resources/gakrcli-logo.svg",
					"dark": "resources/gakrcli-logo.svg"
				}
			},
			{
				"command": "gakrcli.editor.openLast",
				"title": "GakrCLI: Open",
				"icon": {
					"light": "resources/gakrcli-logo.svg",
					"dark": "resources/gakrcli-logo.svg"
				}
			},
			{
				"command": "gakrcli.primaryEditor.open",
				"title": "GakrCLI: Open in Primary Editor",
				"icon": {
					"light": "resources/gakrcli-logo.svg",
					"dark": "resources/gakrcli-logo.svg"
				}
			},
			{
				"command": "gakrcli.window.open",
				"title": "GakrCLI: Open in New Window"
			},
			{
				"command": "gakrcli.createWorktree",
				"title": "GakrCLI: Create Worktree"
			},
			{
				"command": "gakrcli.sidebar.open",
				"title": "GakrCLI: Open in Side Bar",
				"icon": {
					"light": "resources/gakrcli-logo.svg",
					"dark": "resources/gakrcli-logo.svg"
				}
			},
			{
				"command": "gakrcli.newConversation",
				"title": "GakrCLI: New Conversation"
			},
			{
				"command": "gakrcli.update",
				"title": "GakrCLI: Update extension"
			},
			{
				"command": "gakrcli.focus",
				"title": "GakrCLI: Focus input"
			},
			{
				"command": "gakrcli.blur",
				"title": "GakrCLI: Blur input"
			},
			{
				"command": "gakrcli.logout",
				"title": "GakrCLI: Logout"
			},
			{
				"command": "gakrcli.terminal.open",
				"title": "GakrCLI: Open in Terminal",
				"icon": {
					"light": "resources/gakrcli-logo.svg",
					"dark": "resources/gakrcli-logo.svg"
				}
			},
			{
				"command": "gakrcli.acceptProposedDiff",
				"title": "GakrCLI: Accept Proposed Changes",
				"enablement": "gakrcli.viewingProposedDiff",
				"icon": "$(check)"
			},
			{
				"command": "gakrcli.rejectProposedDiff",
				"title": "GakrCLI: Reject Proposed Changes",
				"enablement": "gakrcli.viewingProposedDiff",
				"icon": "$(discard)"
			},
			{
				"command": "gakrcli.insertAtMention",
				"title": "GakrCLI: Insert @-Mention Reference"
			},
			{
				"command": "gakrcli.installPlugin",
				"title": "GakrCLI: Install Plugin"
			},
			{
				"command": "gakrcli.insertAtMentioned",
				"title": "GakrCLI: Insert At-Mentioned"
			},
			{
				"command": "gakrcli.showLogs",
				"title": "GakrCLI: Show Logs"
			},
			{
				"command": "gakrcli.openWalkthrough",
				"title": "GakrCLI: Open Walkthrough"
			}
		],
		"keybindings": [
			{
				"command": "gakrcli.insertAtMention",
				"key": "alt+k",
				"mac": "alt+k",
				"when": "editorTextFocus"
			},
			{
				"command": "gakrcli.focus",
				"key": "cmd+escape",
				"mac": "cmd+escape",
				"win": "ctrl+escape",
				"linux": "ctrl+escape",
				"when": "!config.gakrcliCode.useTerminal && editorTextFocus"
			},
			{
				"command": "gakrcli.blur",
				"key": "cmd+escape",
				"mac": "cmd+escape",
				"win": "ctrl+escape",
				"linux": "ctrl+escape",
				"when": "!config.gakrcliCode.useTerminal && !editorTextFocus"
			},
			{
				"command": "gakrcli.editor.open",
				"key": "cmd+shift+escape",
				"mac": "cmd+shift+escape",
				"win": "ctrl+shift+escape",
				"linux": "ctrl+shift+escape",
				"when": "!config.gakrcliCode.useTerminal"
			},
			{
				"command": "gakrcli.terminal.open.keyboard",
				"key": "cmd+escape",
				"mac": "cmd+escape",
				"win": "ctrl+escape",
				"linux": "ctrl+escape",
				"when": "config.gakrcliCode.useTerminal"
			},
			{
				"command": "gakrcli.insertAtMentioned",
				"key": "cmd+alt+K",
				"mac": "cmd+alt+K",
				"win": "ctrl+alt+K",
				"linux": "ctrl+alt+K",
				"when": "editorTextFocus"
			},
			{
				"command": "gakrcli.newConversation",
				"key": "cmd+n",
				"mac": "cmd+n",
				"win": "ctrl+n",
				"linux": "ctrl+n",
				"when": "config.gakrcliCode.enableNewConversationShortcut && (activeWebviewPanelId == 'gakrcliPanel' || (gakrcli.sideBarActive && !editorFocus && !panelFocus))"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "gakrcli-sidebar",
					"title": "GakrCLI",
					"icon": "resources/gakrcli-logo.svg",
					"when": "gakrcli:doesNotSupportSecondarySidebar"
				},
				{
					"id": "gakrcli-sessions-sidebar",
					"title": "GakrCLI",
					"icon": "resources/gakrcli-logo.svg",
					"when": "gakrcli.sessionsListEnabled"
				}
			],
			"secondarySidebar": [
				{
					"id": "gakrcli-sidebar-secondary",
					"title": "GakrCLI",
					"icon": "resources/gakrcli-logo.svg",
					"when": "!gakrcli:doesNotSupportSecondarySidebar"
				}
			]
		},
		"views": {
			"gakrcli-sidebar": [
				{
					"type": "webview",
					"id": "gakrcliSidebar",
					"name": "GakrCLI",
					"when": "gakrcli:doesNotSupportSecondarySidebar"
				}
			],
			"gakrcli-sidebar-secondary": [
				{
					"type": "webview",
					"id": "gakrcliSidebarSecondary",
					"name": "GakrCLI",
					"when": "!gakrcli:doesNotSupportSecondarySidebar"
				}
			],
			"gakrcli-sessions-sidebar": [
				{
					"type": "webview",
					"id": "gakrcliSessionsList",
					"name": "",
					"when": "gakrcli.sessionsListEnabled"
				}
			]
		},
		"walkthroughs": [
			{
				"id": "gakrcli-walkthrough",
				"title": "Get started with GakrCLI",
				"description": "Learn how to use GakrCLI to write, edit, and understand your code.",
				"steps": [
					{
						"id": "welcome",
						"title": "Your AI coding partner",
						"description": "GakrCLI helps you write, edit, and understand code right in VS Code.",
						"media": {
							"markdown": "resources/walkthrough/step1.md"
						}
					},
					{
						"id": "gakrcli",
						"title": "GakrCLI",
						"description": "Click the GakrCLI icon in the top right corner, or press Ctrl+Escape (Cmd+Escape on Mac) to start a conversation.",
						"media": {
							"markdown": "resources/walkthrough/step2.md"
						},
						"completionEvents": [
							"onCommand:gakrcli.sidebar.open",
							"onCommand:gakrcli.editor.open"
						]
					},
					{
						"id": "chat",
						"title": "Chat with GakrCLI",
						"description": "Type a message and press Enter. Ask questions, request changes, or get help understanding your code. Use @ to mention files for context, or select code first to ask about it.",
						"media": {
							"markdown": "resources/walkthrough/step3.md"
						}
					},
					{
						"id": "sessions",
						"title": "Past conversations",
						"description": "Click the Past Conversations button at the top or type /resume to browse past sessions. You can start a new conversation anytime by clicking the New Chat button.",
						"media": {
							"markdown": "resources/walkthrough/step4.md"
						}
					}
				]
			}
		],
		"menus": {
			"editor/title": [
				{
					"command": "gakrcli.acceptProposedDiff",
					"when": "gakrcli.viewingProposedDiff",
					"group": "navigation"
				},
				{
					"command": "gakrcli.rejectProposedDiff",
					"when": "gakrcli.viewingProposedDiff",
					"group": "navigation"
				},
				{
					"command": "gakrcli.editor.openLast",
					"when": "!config.gakrcliCode.useTerminal",
					"group": "navigation"
				},
				{
					"command": "gakrcli.terminal.open",
					"when": "config.gakrcliCode.useTerminal",
					"group": "navigation"
				}
			],
			"commandPalette": [
				{
					"command": "gakrcli.update",
					"when": "gakrcli.updateSupported"
				},
				{
					"command": "gakrcli.editor.openLast",
					"when": "false"
				},
				{
					"command": "gakrcli.primaryEditor.open",
					"when": "gakrcli.primaryEditorEnabled"
				},
				{
					"command": "gakrcli.createWorktree",
					"when": "gakrcli.createWorktreeEnabled"
				},
				{
					"command": "gakrcli.blur",
					"when": "false"
				},
				{
					"command": "gakrcli.newConversation",
					"when": "false"
				},
				{
					"command": "gakrcli.insertAtMentioned",
					"when": "config.gakrcliCode.useTerminal"
				},
				{
					"command": "gakrcli.insertAtMention",
					"when": "!config.gakrcliCode.useTerminal"
				},
				{
					"command": "gakrcli.installPlugin",
					"when": "gakrcli.updateSupported"
				}
			]
		}
	},
	"capabilities": {
		"untrustedWorkspaces": {
			"supported": false,
			"description": "untusted workspaces are not supported"
		}
	},
	"scripts": {
		"build": "npm run build:extension && npm run build:webview",
		"build:extension": "node esbuild.config.mjs",
		"build:webview": "cd webview && npx vite build",
		"watch": "node esbuild.config.mjs --watch",
		"package": "npx @vscode/vsce package --no-dependencies",
		"lint": "eslint src/ webview/src/",
		"format": "prettier --write \"src/**/*.ts\" \"webview/src/**/*.{ts,tsx}\"",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@types/vscode": "^1.94.0",
		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"@typescript-eslint/parser": "^8.58.0",
		"@vscode/vsce": "^3.0.0",
		"esbuild": "^0.21.0",
		"eslint": "^8.57.0",
		"prettier": "^3.3.0",
		"typescript": "^5.5.0",
		"vitest": "^1.6.0"
	}
}
